{
  "expo": {
    "name": "kikoai-mobile",
    "slug": "kikoai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kikoaimobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kikoai.app",
      "icon": "./assets/expo.icon",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "kikoaimobile",
              "com.googleusercontent.apps.205071192266-4cq6itbajkhcothilspdlcg2tqevmdpd"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kikoai.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "비슷한 옷을 찾으려면 갤러리 접근이 필요해요."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-share-extension",
        {
          "activationRules": [
            { "type": "url", "max": 1 },
            { "type": "text" },
            { "type": "image", "max": 1 }
          ],
          "backgroundColor": {
            "red": 255,
            "green": 255,
            "blue": 255,
            "alpha": 1
          },
          "height": 320
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://dev-ai.kikoai.me",
      "googleClientId": "205071192266-4cq6itbajkhcothilspdlcg2tqevmdpd.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "3eca8caa-f979-4d07-8a63-d418df878533"
      }
    },
    "owner": "chldbsdud"
  }
}
